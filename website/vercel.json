{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "cchat-website.vercel.app" }],
      "destination": "https://cchat.dzhuneyt.com/",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cchat-website.vercel.app" }],
      "destination": "https://cchat.dzhuneyt.com/:path*",
      "statusCode": 301
    }
  ]
}
