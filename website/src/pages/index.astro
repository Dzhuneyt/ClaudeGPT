---
// cchat landing page — static, no client-side JS, accessible, responsive.
// Copy is pulled from the project README so it stays accurate.
const repo = 'https://github.com/Dzhuneyt/cchat';
const readme = 'https://github.com/Dzhuneyt/cchat#readme';
const license = 'https://github.com/Dzhuneyt/cchat/blob/main/LICENSE';
const claudeCode = 'https://docs.claude.com/en/docs/claude-code';
const siteUrl = 'https://cchat.dzhuneyt.com';

const title = 'cchat — your terminal as a private, searchable ChatGPT';
// SEO description: kept to ~150-160 chars so Google doesn't truncate it.
const description =
  'cchat is a lightweight bash harness around Claude Code: a terminal Q&A session like ChatGPT, with every conversation saved as a locally-searchable folder.';
// Social description: kept to ~120 chars so og/twitter previews don't truncate on mobile.
const socialDescription =
  'A bash harness around Claude Code — terminal Q&A like ChatGPT, with every chat saved as a searchable local folder.';
// Absolute, publicly reachable image served from the canonical site (1376x768, > 1200x630).
const ogImage = `${siteUrl}/hero-image.webp`;
const ogImageAlt = 'cchat terminal screenshot — a private, searchable ChatGPT in your terminal';

const features = [
  {
    title: 'Local & private',
    body:
      'Every conversation is stored as plaintext on your own machine under ~/chats/. No web UI, no export buttons, no cloud round-trip.',
  },
  {
    title: 'Greppable history',
    body:
      'cchat search runs ripgrep across every transcript and groups matches by session — recall a fact from any past chat in seconds.',
  },
  {
    title: 'Self-contained sessions',
    body:
      'Each chat is its own folder: the raw JSONL log, a clean markdown transcript, a meta.json, and any files the assistant created.',
  },
  {
    title: 'Zero lock-in',
    body:
      'A single self-contained bash script — no build step. The on-disk format is index-ready for a future SQLite full-text search.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0d1117" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="cchat" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1376" />
    <meta property="og:image:height" content="768" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="topbar">
      <span class="brand"><span class="prompt">$</span>&nbsp;cchat</span>
      <nav aria-label="Primary">
        <a href="#features">Features</a>
        <a href="#install">Install</a>
        <a href={readme}>Docs</a>
        <a href={repo} class="ghlink">GitHub&nbsp;↗</a>
      </nav>
    </header>

    <main id="main">
      <section class="hero" aria-labelledby="hero-heading">
        <div class="hero-copy">
          <h1 id="hero-heading">
            Your terminal as a private,<br /><span class="accent">searchable ChatGPT</span>
          </h1>
          <p class="tagline">
            Every conversation saved as a local, greppable folder. cchat is a lightweight bash
            harness around <a href={claudeCode}>Claude Code</a> — terminal Q&amp;A that feels like
            the Claude desktop app, with nothing leaving your machine.
          </p>
          <div class="cta-row">
            <a class="btn btn-primary" href={repo}>View on GitHub</a>
            <a class="btn btn-ghost" href="#install">Quick install</a>
          </div>
        </div>
        <div class="hero-art">
          <img
            src="/hero-image.webp"
            width="800"
            height="450"
            alt="cchat — your terminal as a private, searchable ChatGPT"
            fetchpriority="high"
          />
        </div>
      </section>

      <section id="features" class="section" aria-labelledby="features-heading">
        <h2 id="features-heading">What you get</h2>
        <ul class="features">
          {
            features.map((f) => (
              <li class="feature">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <section id="install" class="section" aria-labelledby="install-heading">
        <h2 id="install-heading">Install</h2>
        <p class="section-lead">
          cchat is a single bash script. Clone it, make it executable, and symlink it onto your
          <code>PATH</code>.
        </p>
        <pre class="code"><code>git clone git@github.com:Dzhuneyt/cchat.git
cd cchat
chmod +x cchat
ln -s "$PWD/cchat" /usr/local/bin/cchat</code></pre>
        <p class="deps">
          Needs <code>claude</code> (sessions), <code>jq</code> (transcript rendering) and
          <code>rg</code> / ripgrep (search).
        </p>
      </section>

      <section id="usage" class="section" aria-labelledby="usage-heading">
        <h2 id="usage-heading">Usage</h2>
        <pre class="code"><code>cchat                   # prompts for a topic, then opens the session
cchat "tax deadline"    # skip the prompt — topic preset from the argument
cchat search "deadline" # ripgrep across every transcript, grouped by session</code></pre>
        <p class="section-lead">
          End the session the way you normally exit Claude Code; the transcript is archived
          automatically and the saved folder path is printed. Full details live in the
          <a href={readme}>README</a>.
        </p>
      </section>
    </main>

    <footer class="footer">
      <nav aria-label="Footer">
        <a href={repo}>GitHub</a>
        <a href={license}>MIT License</a>
        <a href={readme}>Docs</a>
      </nav>
      <p class="credit">© Dzhuneyt — released under the MIT License.</p>
    </footer>

    <style>
      :root {
        --bg: #0d1117;
        --bg-elev: #161b22;
        --border: #30363d;
        --text: #e6edf3;
        --muted: #8b949e;
        --accent: #4eaa25;
        --accent-2: #58a6ff;
        --radius: 10px;
        --maxw: 1040px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--accent-2);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      code,
      pre {
        font-family: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, Consolas, monospace;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--accent);
        color: #07140a;
        padding: 0.5rem 1rem;
        border-radius: 0 0 var(--radius) 0;
        z-index: 10;
      }
      .skip-link:focus {
        left: 0;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 1.1rem 1.25rem;
        flex-wrap: wrap;
      }
      .brand {
        font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
        font-weight: 700;
        font-size: 1.15rem;
      }
      .brand .prompt {
        color: var(--accent);
      }
      .topbar nav {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .topbar nav a {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .topbar nav a:hover {
        color: var(--text);
      }
      .topbar .ghlink {
        color: var(--text);
        font-weight: 600;
      }

      main {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 1.05fr 1fr;
        gap: 2.5rem;
        align-items: center;
        padding: 3.5rem 0 4rem;
      }
      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.1rem);
        line-height: 1.12;
        margin: 0 0 1.1rem;
        letter-spacing: -0.02em;
      }
      .hero .accent {
        color: var(--accent);
      }
      .tagline {
        font-size: 1.12rem;
        color: var(--muted);
        max-width: 38ch;
        margin: 0 0 1.75rem;
      }
      .cta-row {
        display: flex;
        gap: 0.85rem;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-block;
        padding: 0.7rem 1.35rem;
        border-radius: var(--radius);
        font-weight: 600;
        border: 1px solid transparent;
        transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;
      }
      .btn:hover {
        text-decoration: none;
        transform: translateY(-1px);
      }
      .btn-primary {
        background: var(--accent);
        color: #07140a;
      }
      .btn-primary:hover {
        background: #5bc02b;
      }
      .btn-ghost {
        border-color: var(--border);
        color: var(--text);
      }
      .btn-ghost:hover {
        border-color: var(--muted);
      }
      .hero-art img {
        width: 100%;
        height: auto;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
      }

      .section {
        padding: 2.5rem 0;
        border-top: 1px solid var(--border);
      }
      .section h2 {
        font-size: clamp(1.5rem, 3vw, 2rem);
        margin: 0 0 1.25rem;
        letter-spacing: -0.01em;
      }
      .section-lead {
        color: var(--muted);
        max-width: 65ch;
      }
      .section-lead code,
      .deps code {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.05rem 0.35rem;
        font-size: 0.9em;
      }

      .features {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
      .feature {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem 1.35rem;
      }
      .feature h3 {
        margin: 0 0 0.4rem;
        font-size: 1.1rem;
      }
      .feature p {
        margin: 0;
        color: var(--muted);
        font-size: 0.97rem;
      }

      .code {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.1rem 1.25rem;
        overflow-x: auto;
        font-size: 0.92rem;
        line-height: 1.7;
        color: var(--text);
      }
      .deps {
        color: var(--muted);
        font-size: 0.95rem;
      }

      .footer {
        max-width: var(--maxw);
        margin: 2rem auto 0;
        padding: 2rem 1.25rem 3rem;
        border-top: 1px solid var(--border);
        text-align: center;
      }
      .footer nav {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
      }
      .footer .credit {
        color: var(--muted);
        font-size: 0.9rem;
        margin: 0;
      }

      @media (max-width: 760px) {
        .hero {
          grid-template-columns: 1fr;
          padding: 2.25rem 0 2.75rem;
          gap: 2rem;
        }
        .hero-art {
          order: -1;
        }
        .features {
          grid-template-columns: 1fr;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .btn:hover {
          transform: none;
        }
      }
    </style>
  </body>
</html>
